#!/usr/bin/env bash

set -euo pipefail

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$staged_files" ] && exit 0

bom_found=0
while IFS= read -r file; do
  [ -z "$file" ] && continue
  [ ! -f "$file" ] && continue

  header="$(head -c 3 "$file" | od -An -t x1 | tr -d ' \n' || true)"
  if [ "$header" = "efbbbf" ]; then
    echo "BOM detectado (UTF-8 com BOM): $file"
    bom_found=1
  fi
done <<< "$staged_files"

if [ "$bom_found" -ne 0 ]; then
  echo "Commit bloqueado. Converta os arquivos para UTF-8 sem BOM e tente novamente."
  exit 1
fi

exit 0
